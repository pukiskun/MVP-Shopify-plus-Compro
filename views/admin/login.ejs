<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Portal</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .login-container {
      max-width: 420px;
      margin: 6rem auto;
      padding: 0 1.5rem;
    }
    .login-header {
      text-align: center;
      margin-bottom: 2rem;
    }
    .login-header h2 {
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #ffffff 0%, var(--accent-primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 0.5rem;
    }
    .login-header p {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }
  </style>
</head>
<body style="background-color: var(--bg-primary); color: var(--text-primary); font-family: var(--font-sans);">

  <div class="login-container">
    <div class="login-header">
      <h2>Admin Control Center</h2>
      <p>Please authorize yourself to manage the product catalog</p>
    </div>
    
    <div class="contact-form-card">
      <% if (error) { %>
        <div class="alert alert-danger" style="margin-bottom: 1.5rem;">
          <%= error %>
        </div>
      <% } %>
      
      <form action="/ad-minpanel/login" method="POST" autocomplete="off">
        <div class="form-group">
          <label for="username" class="form-label">Admin Username</label>
          <input type="text" id="username" name="username" class="form-input" placeholder="Enter admin username" value="<%= formData.username || '' %>" required autofocus>
        </div>
        
        <div class="form-group">
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required>
        </div>
        
        <button type="submit" class="btn" style="width: 100%; margin-top: 1rem; font-size: 1rem;">Authenticate</button>
      </form>
      
      <div style="text-align: center; margin-top: 1.5rem;">
        <a href="/" style="color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; transition: var(--transition-fast);">
          ← Return to Storefront
        </a>
      </div>
    </div>
  </div>

</body>
</html>
