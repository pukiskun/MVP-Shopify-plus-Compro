<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Panel</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-header-nav {
      background-color: var(--bg-secondary);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .admin-brand {
      font-weight: 700;
      color: var(--text-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .admin-brand span {
      color: var(--accent-primary);
    }
    .admin-container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 2rem;
    }
    .dashboard-actions-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }
    .banner-table-wrapper {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      overflow-x: auto;
      margin-bottom: 3rem;
    }
    .banner-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    .banner-table th, .banner-table td {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      vertical-align: middle;
    }
    .banner-table th {
      background-color: rgba(15, 23, 42, 0.4);
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .banner-table tr:last-child td {
      border-bottom: none;
    }
    .tbl-thumb {
      width: 120px;
      height: 45px;
      object-fit: cover;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-color);
    }
    .actions-cell {
      display: flex;
      gap: 0.75rem;
      align-items: center;
    }
    .card-form {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 2rem;
    }
    .form-group {
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .form-group label {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-secondary);
    }
    .form-control {
      background-color: var(--bg-primary);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.75rem 1rem;
      border-radius: var(--radius-sm);
      font-family: var(--font-sans);
      font-size: 0.95rem;
      width: 100%;
      transition: var(--transition-fast);
    }
    .form-control:focus {
      outline: none;
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 1px var(--accent-primary);
    }
    .alert {
      padding: 1rem 1.25rem;
      border-radius: var(--radius-sm);
      margin-bottom: 1.5rem;
      font-size: 0.95rem;
    }
    .alert-error {
      background-color: rgba(239, 68, 68, 0.15);
      border: 1px solid var(--danger);
      color: #fca5a5;
    }
    .alert-success {
      background-color: rgba(16, 185, 129, 0.15);
      border: 1px solid var(--accent-primary);
      color: #a7f3d0;
    }
    .order-btns {
      display: flex;
      gap: 0.25rem;
    }
    .btn-order {
      background: none;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      cursor: pointer;
      width: 32px;
      height: 32px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition-fast);
    }
    .btn-order:hover {
      border-color: var(--accent-primary);
      color: var(--accent-primary);
      background-color: var(--bg-primary);
    }
  </style>
</head>
<body style="background-color: var(--bg-primary); color: var(--text-primary); font-family: var(--font-sans);">

  <header class="admin-header-nav">
    <a href="/ad-minpanel/products" class="admin-brand">
      <span>✦</span> MVP Shopify Admin Panel
    </a>
    <div style="display: flex; gap: 1.5rem; align-items: center;">
      <a href="/ad-minpanel/products" style="color: var(--text-secondary); text-decoration: none; font-size: 0.95rem;">Catalog Dashboard</a>
      <a href="/ad-minpanel/inventory" style="color: var(--text-secondary); text-decoration: none; font-size: 0.95rem;">Inventory</a>
      <a href="/ad-minpanel/orders" style="color: var(--text-secondary); text-decoration: none; font-size: 0.95rem;">Order History</a>
      <a href="/ad-minpanel/banners" style="color: var(--text-primary); text-decoration: none; font-size: 0.95rem; font-weight: 600;">Banners</a>
      <a href="/ad-minpanel/page-builder" style="color: var(--text-secondary); text-decoration: none; font-size: 0.95rem;">Page Builder</a>
      <a href="/ad-minpanel/logs" style="color: var(--text-secondary); text-decoration: none; font-size: 0.95rem;">Audit Logs</a>
      <a href="/ad-minpanel/logout" class="btn btn-secondary" style="padding: 0.5rem 1.25rem; font-size: 0.85rem;">Sign Out</a>
    </div>
  </header>

  <div class="admin-container">
    <div class="dashboard-actions-header">
      <div>
        <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.25rem;">Homepage Banner Manager</h2>
        <p style="color: var(--text-secondary); font-size: 0.95rem;">Upload and reorder sliding banners appearing at the top of the homepage</p>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">Active Banners</h3>
    <div class="banner-table-wrapper">
      <table class="banner-table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Image Thumbnail</th>
            <th>Banner Title</th>
            <th>Banner Group</th>
            <th>Target Link URL</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (banners.length === 0) { %>
            <tr>
              <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 3rem;">
                No banners found in the database. Please add one using the form below.
              </td>
            </tr>
          <% } else { %>
            <% banners.forEach((banner, idx) => { %>
              <tr>
                <td style="width: 100px;">
                  <div class="order-btns">
                    <form action="/ad-minpanel/banners/<%= banner.id %>/up" method="POST" style="display: inline;">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="btn-order" title="Move Up" <%= idx === 0 ? 'disabled style="opacity: 0.3; cursor: not-allowed;"' : '' %>>▲</button>
                    </form>
                    <form action="/ad-minpanel/banners/<%= banner.id %>/down" method="POST" style="display: inline;">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="btn-order" title="Move Down" <%= idx === banners.length - 1 ? 'disabled style="opacity: 0.3; cursor: not-allowed;"' : '' %>>▼</button>
                    </form>
                  </div>
                </td>
                <td>
                  <img src="<%= banner.image_url %>" alt="<%= banner.title %>" class="tbl-thumb">
                </td>
                <td><%= banner.title %></td>
                <td>
                  <strong><%= banner.group_name %></strong>
                  <% if (banner.target_width && banner.target_height) { %>
                    <br>
                    <code style="background-color: var(--bg-primary); padding: 0.25rem 0.5rem; border-radius: 4px; border: 1px solid var(--border-color); font-size: 0.85rem;"><%= banner.target_width %>x<%= banner.target_height %></code>
                  <% } else { %>
                    <br>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">(No dimensions set yet)</span>
                  <% } %>
                </td>
                <td>
                  <% if (banner.link_url) { %>
                    <a href="<%= banner.link_url %>" target="_blank" style="color: var(--accent-primary); text-decoration: none;"><%= banner.link_url %></a>
                  <% } else { %>
                    <span style="color: var(--text-muted);">None</span>
                  <% } %>
                </td>
                <td style="width: 180px;">
                  <div class="actions-cell">
                    <a href="/ad-minpanel/banners?edit=<%= banner.id %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; min-height: unset; height: 32px;">Edit</a>
                    <form action="/ad-minpanel/banners/<%= banner.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this banner?');">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; min-height: unset; height: 32px;">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="forms-container" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; align-items: start; margin-bottom: 3rem;">
      <div class="card-form">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 700;">
          <%= editingBanner ? 'Edit Banner: ' + editingBanner.title : 'Add New Homepage Banner' %>
        </h3>
        
        <form action="<%= editingBanner ? '/ad-minpanel/banners/' + editingBanner.id + '/edit' : '/ad-minpanel/banners/create' %>?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="form-group">
            <label for="title">Banner Title *</label>
            <input type="text" id="title" name="title" class="form-control" placeholder="Enter descriptive banner title" value="<%= editingBanner ? editingBanner.title : '' %>" required>
          </div>

          <div class="form-group">
            <label for="groupId">Banner Group *</label>
            <select id="groupId" name="groupId" class="form-control" required>
              <% bannerGroups.forEach(group => { %>
                <option value="<%= group.id %>" <%= (editingBanner && editingBanner.group_id === group.id) || (!editingBanner && group.id === 1) ? 'selected' : '' %>>
                  <%= group.group_name %> 
                  <% if (group.target_width && group.target_height) { %>
                    (<%= group.target_width %>x<%= group.target_height %>)
                  <% } else { %>
                    (First upload defines dimensions)
                  <% } %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="link_url">Click Destination URL (Link URL)</label>
            <input type="text" id="link_url" name="link_url" class="form-control" placeholder="e.g. /catalog or /catalog?type=Electronics (leave blank for none)" value="<%= editingBanner ? editingBanner.link_url : '' %>">
          </div>

          <div class="form-group">
            <label for="position">Sequence Position Placement</label>
            <select id="position" name="position" class="form-control">
              <% if (editingBanner) { %>
                <option value="current" selected>Keep Current Sequence Order Position</option>
              <% } %>
              <option value="first" <%= !editingBanner && banners.length === 0 ? 'selected' : '' %>>Insert at the Very Beginning (First)</option>
              <option value="last" <%= !editingBanner && banners.length > 0 ? 'selected' : '' %>>Insert at the Very End (Last)</option>
              <% if (banners.length > 0) { %>
                <optgroup label="Place In-Between / After Banner">
                  <% banners.forEach(b => { %>
                    <% if (!editingBanner || b.id !== editingBanner.id) { %>
                      <option value="after:<%= b.id %>">After Banner: "<%= b.title %>"</option>
                    <% } %>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>

          <div class="form-group" style="margin-bottom: 2rem;">
            <label for="bannerImage">Banner Image File * <%= editingBanner ? '(Leave empty to keep existing image)' : '' %></label>
            <input type="file" id="bannerImage" name="bannerImage" class="form-control" accept="image/*" <%= editingBanner ? '' : 'required' %>>
            <% if (editingBanner) { %>
              <div style="margin-top: 0.5rem; display: flex; align-items: center; gap: 0.75rem;">
                <span style="font-size: 0.85rem; color: var(--text-secondary);">Current Image:</span>
                <img src="<%= editingBanner.image_url %>" alt="Current image" style="height: 35px; border-radius: 4px; border: 1px solid var(--border-color);">
              </div>
            <% } %>
          </div>

          <div style="display: flex; gap: 1rem;">
            <button type="submit" class="btn" style="flex: 1;"><%= editingBanner ? 'Update Banner Details' : 'Create & Upload Banner' %></button>
            <% if (editingBanner) { %>
              <a href="/ad-minpanel/banners" class="btn btn-secondary" style="flex: 1;">Cancel Editing</a>
            <% } %>
          </div>
        </form>
      </div>

      <div class="card-form">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 700;">Create New Banner Group</h3>
        <form action="/ad-minpanel/banners/groups/new" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="form-group">
            <label for="group_name">Group Name *</label>
            <input type="text" id="group_name" name="group_name" class="form-control" placeholder="e.g. Mobile Carousel, Promo Grid" required>
          </div>
          
          <div class="form-group">
            <label for="target_width">Target Width (px)</label>
            <input type="number" id="target_width" name="target_width" class="form-control" placeholder="e.g. 1920 (optional)">
          </div>
          
          <div class="form-group" style="margin-bottom: 2rem;">
            <label for="target_height">Target Height (px)</label>
            <input type="number" id="target_height" name="target_height" class="form-control" placeholder="e.g. 600 (optional)">
          </div>
          
          <button type="submit" class="btn" style="width: 100%;">Create Banner Group</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
