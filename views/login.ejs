<%- include('partials/header') %>

<div style="max-width: 480px; margin: 3rem auto; padding: 0 1.5rem;">
  <div class="login-header" style="text-align: center; margin-bottom: 2rem;">
    <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">Customer Login</h2>
    <p style="color: var(--text-secondary);">Access your account to manage checkout and orders</p>
  </div>

  <div class="contact-form-card" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 2rem;">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" style="margin-bottom: 1.5rem; background-color: rgba(239, 68, 68, 0.1); color: var(--danger); border: 1px solid rgba(239, 68, 68, 0.2); padding: 0.75rem; border-radius: var(--radius-sm);">
        <%= error %>
      </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success" style="margin-bottom: 1.5rem; background-color: rgba(16, 185, 129, 0.1); color: var(--accent-primary); border: 1px solid rgba(16, 185, 129, 0.2); padding: 0.75rem; border-radius: var(--radius-sm);">
        <%= success %>
      </div>
    <% } %>

    <form action="/login" method="POST" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '' %>">

      <div class="form-group" style="margin-bottom: 1.25rem;">
        <label for="email" class="form-label" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Email Address</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="john@example.com" value="<%= typeof formData !== 'undefined' ? formData.email : '' %>" required autofocus style="width: 100%; padding: 0.75rem; border-radius: var(--radius-sm); border: 1px solid var(--border-color); background-color: var(--bg-primary); color: var(--text-primary);">
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label for="password" class="form-label" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Password</label>
        <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required style="width: 100%; padding: 0.75rem; border-radius: var(--radius-sm); border: 1px solid var(--border-color); background-color: var(--bg-primary); color: var(--text-primary);">
      </div>

      <button type="submit" class="btn" style="width: 100%; padding: 0.75rem; font-size: 1rem; cursor: pointer;">Log In</button>
    </form>

    <div style="text-align: center; margin-top: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
      <p style="color: var(--text-secondary); font-size: 0.9rem;">
        New customer? <a href="/register<%= (typeof redirect !== 'undefined' && redirect) ? '?redirect=' + encodeURIComponent(redirect) : '' %>" style="color: var(--accent-primary); text-decoration: none; font-weight: 600;">Create an account here</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
