<%- include('partials/header') %>

<style>
  .log-badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .badge-pending { background-color: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); }
  .badge-paid { background-color: rgba(16, 185, 129, 0.1); color: var(--accent-primary); border: 1px solid rgba(16, 185, 129, 0.2); }
  .badge-shipped { background-color: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2); }
  .badge-delivered { background-color: rgba(99, 102, 241, 0.1); color: #6366f1; border: 1px solid rgba(99, 102, 241, 0.2); }
  .badge-cancelled { background-color: rgba(239, 68, 68, 0.1); color: var(--danger); border: 1px solid rgba(239, 68, 68, 0.2); }

  .order-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    margin-bottom: 2rem;
  }
  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .order-details-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    background-color: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .order-details-table th, .order-details-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }
  .order-details-table th {
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    font-weight: 600;
  }
  .order-details-table tr:last-child td {
    border-bottom: none;
  }
  
  /* Progress tracker line */
  .progress-tracker {
    display: flex;
    justify-content: space-between;
    margin: 1.5rem 0;
    position: relative;
    padding: 0 1rem;
  }
  .progress-tracker::before {
    content: '';
    position: absolute;
    top: 10px;
    left: 2rem;
    right: 2rem;
    height: 3px;
    background-color: var(--border-color);
    z-index: 1;
  }
  .progress-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    position: relative;
    z-index: 2;
  }
  .progress-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background-color: var(--bg-secondary);
    border: 3px solid var(--border-color);
    margin-bottom: 0.5rem;
    transition: var(--transition-normal);
  }
  .progress-step.active {
    color: var(--accent-primary);
  }
  .progress-step.active .progress-dot {
    background-color: var(--accent-primary);
    border-color: var(--accent-primary);
    box-shadow: 0 0 10px var(--accent-glow);
  }
  .progress-step.cancelled {
    color: var(--danger);
  }
  .progress-step.cancelled .progress-dot {
    background-color: var(--danger);
    border-color: var(--danger);
    box-shadow: 0 0 10px rgba(239, 68, 68, 0.3);
  }
</style>

<h1 style="font-size: 2.25rem; margin-bottom: 2rem;">My Purchase Orders</h1>

<% if (orders.length === 0) { %>
  <div class="empty-cart-container" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: var(--radius-md);">
    <div class="empty-cart-icon">📦</div>
    <h2>No Orders Placed Yet</h2>
    <p style="color: var(--text-secondary); margin-bottom: 2rem;">You haven't placed any checkout transactions in this session.</p>
    <a href="/catalog" class="btn">Start Shopping</a>
  </div>
<% } else { %>
  <div style="display: grid; gap: 2rem;">
    <% orders.forEach(function(order) { %>
      <div class="order-card">
        
        <div class="order-header">
          <div>
            <span style="color: var(--text-muted); font-size: 0.8rem; display: block; text-transform: uppercase;">Order Reference</span>
            <code style="font-size: 0.95rem; color: var(--accent-primary);"><%= order.order_uuid %></code>
          </div>
          
          <div style="display: flex; gap: 1.5rem; align-items: center;">
            <!-- Current status tag -->
            <div>
              <span style="color: var(--text-muted); font-size: 0.8rem; display: block; text-transform: uppercase; text-align: right; margin-bottom: 0.25rem;">Status</span>
              <% if (order.status === 'PENDING') { %>
                <span class="log-badge badge-pending">PENDING</span>
              <% } else if (order.status === 'PAID') { %>
                <span class="log-badge badge-paid">PAID</span>
              <% } else if (order.status === 'SHIPPED') { %>
                <span class="log-badge badge-shipped">SHIPPED</span>
              <% } else if (order.status === 'DELIVERED') { %>
                <span class="log-badge badge-delivered">DELIVERED</span>
              <% } else if (order.status === 'CANCELLED') { %>
                <span class="log-badge badge-cancelled">CANCELLED</span>
              <% } %>
            </div>

            <!-- Complete payment & Download PDF link -->
            <div style="display: flex; gap: 0.5rem; align-items: center;">
              <a href="/orders/invoice/<%= order.order_uuid %>" class="btn" target="_blank" style="min-height: 44px; padding: 0 1.25rem; font-size: 0.85rem; background-color: transparent; border: 1px solid var(--border-color); color: var(--text-primary); text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">Download PDF Invoice</a>
              <% if (order.status === 'PENDING') { %>
                <a href="/checkout/pay/<%= order.order_uuid %>" class="btn" style="min-height: 44px; padding: 0 1.25rem; font-size: 0.85rem;">Complete Payment</a>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Progress Tracker Bar (Sprint 6) -->
        <% if (order.status !== 'CANCELLED') { %>
          <div class="progress-tracker">
            <div class="progress-step <%= (order.status === 'PENDING' || order.status === 'PAID' || order.status === 'SHIPPED' || order.status === 'DELIVERED') ? 'active' : '' %>">
              <div class="progress-dot"></div>
              <span>Placed</span>
            </div>
            <div class="progress-step <%= (order.status === 'PAID' || order.status === 'SHIPPED' || order.status === 'DELIVERED') ? 'active' : '' %>">
              <div class="progress-dot"></div>
              <span>Paid</span>
            </div>
            <div class="progress-step <%= (order.status === 'SHIPPED' || order.status === 'DELIVERED') ? 'active' : '' %>">
              <div class="progress-dot"></div>
              <span>Shipped</span>
            </div>
            <div class="progress-step <%= (order.status === 'DELIVERED') ? 'active' : '' %>">
              <div class="progress-dot"></div>
              <span>Delivered</span>
            </div>
          </div>
        <% } else { %>
          <!-- Cancelled State Tracker -->
          <div class="progress-tracker">
            <div class="progress-step active">
              <div class="progress-dot"></div>
              <span>Placed</span>
            </div>
            <div class="progress-step cancelled">
              <div class="progress-dot"></div>
              <span>Cancelled</span>
            </div>
          </div>
        <% } %>

        <div style="margin-top: 1.5rem;">
          <span style="color: var(--text-muted); font-size: 0.8rem; display: block; text-transform: uppercase;">Delivery Address</span>
          <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem; white-space: pre-line;"><%= order.customer_address %></p>
        </div>

        <div style="overflow-x: auto;">
          <table class="order-details-table">
            <thead>
              <tr>
                <th>Product Item</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th style="text-align: right;">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(function(item) { %>
                <tr>
                  <td style="font-weight: 600; color: var(--text-primary);"><%= item.item_name %></td>
                  <td>
                    <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(item.price) %>
                  </td>
                  <td><%= item.quantity %></td>
                  <td style="text-align: right; font-weight: 600; color: var(--text-primary);">
                    <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(item.price * item.quantity) %>
                  </td>
                </tr>
              <% }); %>
              <tr style="background-color: rgba(255, 255, 255, 0.01);">
                <td colspan="2" style="border: none;"></td>
                <td style="font-weight: 600; border: none; color: var(--text-muted); font-size: 0.9rem;">Grand Total:</td>
                <td style="text-align: right; font-weight: 700; border: none; color: var(--accent-primary); font-size: 1.15rem;">
                  <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(order.total_price) %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    <% }); %>
  </div>
<% } %>

<%- include('partials/footer') %>
