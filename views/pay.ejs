<%- include('partials/header') %>

<div style="max-width: 600px; margin: 3rem auto; padding: 0 1rem;">
  <div style="background-color: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-lg);">
    
    <div style="text-align: center; margin-bottom: 2rem;">
      <span style="font-size: 3rem; color: var(--accent-primary); display: block; margin-bottom: 1rem;">💳</span>
      <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;"><%= title %></h2>
      <p style="color: var(--text-secondary); font-size: 0.95rem;">This is a secure checkout payment simulator for testing storefront transactions.</p>
    </div>

    <div style="background-color: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 1.5rem; margin-bottom: 2rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <span style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Order ID</span>
        <code style="color: var(--text-primary); font-size: 0.9rem;"><%= order.order_uuid %></code>
      </div>
      
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <span style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Customer</span>
        <strong style="color: var(--text-primary); font-size: 0.95rem;"><%= order.customer_name %></strong>
      </div>

      <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--border-color); padding-top: 1rem; margin-top: 1rem;">
        <span style="color: var(--text-primary); font-weight: 600; font-size: 1.05rem;">Amount Due</span>
        <strong style="color: var(--accent-primary); font-size: 1.4rem;">
          <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(order.total_price) %>
        </strong>
      </div>
    </div>

    <!-- Confirm simulated payment form -->
    <form action="/checkout/pay/<%= order.order_uuid %>" method="POST">
      <button type="submit" class="btn" style="width: 100%; min-height: 48px; font-size: 1.1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem; box-shadow: var(--shadow-glow);">
        Confirm Simulated Payment (PAID)
      </button>
    </form>

    <div style="margin-top: 1.5rem; text-align: center;">
      <a href="/cart" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem; transition: var(--transition-fast);">
        Cancel Payment & Edit Cart
      </a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
